{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "installCommand": "npm ci",
        "buildCommand": "npm run build",
        "outputDirectory": ".next",
        "nodeVersion": "22.x"
      }
    }
  ],
  "env": {
    "NEXT_PUBLIC_STATE": "colorado"
  }
}