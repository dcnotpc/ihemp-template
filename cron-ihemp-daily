#
# Important: This runs in system time (UTC). 
# America/Detroit is UTC-4 during EDT (summer), UTC-5 during EST (winter)

# For EDT (April-October): 11:30 UTC
30 11 * * * /bin/bash /home/dcnotpc420/.openclaw/workspace/schedule-daily-report.sh

